{
	"name": "AI Agent Sandbox",
	"build": {
		"dockerfile": "Dockerfile",
		"context": ".."
	},
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts"
		},
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": "true",
			"username": "vscode",
			"userUid": "1000",
			"userGid": "1000",
			"upgradePackages": "true"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance",
				"ms-toolsai.jupyter",
				"dbaeumer.vscode-eslint"
			]
		}
	},
	"postCreateCommand": "sudo chown -R vscode:vscode . && pip install --user -r requirements.txt",
	"remoteUser": "vscode"
}